{
  "name": "@pulkitlather/sera-sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for Sera Protocol",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "author": "Pulkit Lather <pulkitlather.work@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/pulkit136/sera-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pulkit136/sera-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/pulkit136/sera-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "sera",
    "protocol",
    "sdk",
    "stablecoin",
    "fx",
    "clob",
    "defi",
    "typescript"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "clean": "rimraf dist coverage",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test",
    "docs:clean": "rimraf docs/api",
    "docs:build": "typedoc",
    "docs": "npm run docs:clean && npm run docs:build"
  },
  "peerDependencies": {
    "ethers": "^6.0.0",
    "viem": "^2.54.3"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    },
    "ethers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.0.0"
  }
}
